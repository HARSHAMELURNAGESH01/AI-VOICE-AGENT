# Required for everything
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Optional model overrides
LENA_MODEL=claude-sonnet-4-6
LENA_QA_MODEL=claude-sonnet-4-6
LENA_CALLER_MODEL=claude-sonnet-4-6

# Only needed for the phone adapter (telephony/)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_token
TWILIO_FROM_NUMBER=+15551234567
PUBLIC_BASE_URL=https://your-ngrok-url.ngrok-free.app

# SMS follow-up: "log" composes+stores without sending (demo-safe default);
# "twilio" actually sends (requires A2P 10DLC registration on your number)
SMS_MODE=log
